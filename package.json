{
  "name": "@asharirfan/repolens",
  "version": "0.0.4",
  "description": "Analyze any local or remote GitHub repository and generate a clear overview of its architecture, dependencies, and structure.",
  "type": "module",
  "bin": {
    "repolens": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "cli",
    "repository",
    "analysis",
    "architecture",
    "developer-tools",
    "code-analysis",
    "github"
  ],
  "author": "Ashar Irfan",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/asharirfan/repo-lens.git"
  },
  "homepage": "https://github.com/asharirfan/repo-lens#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@octokit/rest": "^21.0.0",
    "boxen": "^7.1.0",
    "cli-table3": "^0.6.3",
    "commander": "^12.0.0",
    "fs-extra": "^11.2.0",
    "glob": "^13.0.0",
    "ora": "^8.0.0",
    "picocolors": "^1.1.0",
    "simple-git": "^3.22.0",
    "smol-toml": "^1.3.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.0",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.2.0",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
